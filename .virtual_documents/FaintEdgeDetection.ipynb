        m, n = self._I.shape
        self._handle.m = m
        self._handle.n = n
        self._handle.N = m * n
        self._handle.rSize = (self._handle.N, self._handle.N)
        
        max_size = int(np.ceil(self._handle.N / 3.0))
        self._pixel_scores = [None] * max_size


import numpy as np
import cv2
import time
from queue import PriorityQueue
