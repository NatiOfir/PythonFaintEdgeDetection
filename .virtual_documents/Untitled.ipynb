import numpy as np
import cv2
import time
from threading import Thread, Lock
from typing import Tuple
from dataclasses import dataclass
import math
import os

# Constants
TYPE = np.float64
ZERO = 0.0

@dataclass
class MyParam:
    slidingWindow: int = 0
    noisyImage: bool = False
    parallel: bool = True
    splitPoints: int = 0
    printToScreen: bool = True
    filterWidth: int = 2
    fibers: bool = False
    patchSize: int = 16
    parallelJump: int = 2
    minLevelOfStitching: int = 0
    normType: int = 2
    interpolation: bool = True
    removeEpsilon: float = 1.0
    sigma: float = 1.0
    minContrast: float = 2.0
    maxTurn: int = 45
    nmsFact: float = 0.6
    maxNumOfEdges: int = 1000

def read_image(img_path: str, kill: bool = False) -> np.ndarray:
    """Read image in grayscale"""
    image = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)
    if image is None:
        print("Could not open or find the image")
        if kill:
            exit(-1)
    return image

def show_image(image: np.ndarray, fig: int, scale: float = 1, wait: bool = False):
    """Display image with optional scaling"""
    i_big = cv2.resize(image, (0, 0), fx=scale, fy=scale)
    win_name = f"Window {fig}"
    cv2.namedWindow(win_name, cv2.WINDOW_AUTOSIZE)
    cv2.imshow(win_name, i_big)
    if wait:
        cv2.waitKey(0)

def max_value(m: np.ndarray) -> float:
    """Get maximum value in array"""
    return np.max(m)

# Global mutex for edge map updates
E_mutex = Lock()

def my_wrapper(I: np.ndarray, E: np.ndarray, prm: MyParam, 
               y_range: Tuple[int, int], x_range: Tuple[int, int]):
    """Process image region and update edge map"""
    from detector import Detector  # Import here to avoid circular imports
    d = Detector(I, prm)
    cur_E = d.run_im()
    
    with E_mutex:
        y_slice = slice(y_range[0], y_range[1])
        x_slice = slice(x_range[0], x_range[1])
        E[y_slice, x_slice] = np.maximum(E[y_slice, x_slice], cur_E)

def my_run_im(I: np.ndarray, prm: MyParam) -> np.ndarray:
    """Run edge detection on image"""
    if not prm.slidingWindow:
        E = np.zeros(I.shape, dtype=TYPE)
        my_wrapper(I, E, prm, (0, I.shape[0]), (0, I.shape[1]))
    else:
        prm.parallel = True
        prm.printToScreen = False
        
        # Calculate sliding window size
        s = min(I.shape[1], I.shape[0])
        j = math.log2(s)
        j = math.floor(j) - 1 if j == math.floor(j) else math.floor(j)
        s = int(2**j) + 1
        s = min(s, prm.slidingWindow)
        
        E = np.zeros(I.shape, dtype=TYPE)
        ds = (s - 1) // 2
        
        start = time.time()
        ITER = 0
        total_iterations = ((I.shape[1] // ds + 1) * (I.shape[0] // ds + 1))
        print(f"{total_iterations} ITERATIONS")
        print(f"{s} BLOCK")
        
        threads = []
        parallel = False
        
        for x in range(0, I.shape[1], ds):
            for y in range(0, I.shape[0], ds):
                # Calculate ranges
                x_end = min(x + s, I.shape[1])
                x_start = x_end - s if x + s >= I.shape[1] else x
                y_end = min(y + s, I.shape[0])
                y_start = y_end - s if y + s >= I.shape[0] else y
                
                print(f"ITER {ITER + 1}")
                ITER += 1
                
                cur_I = I[y_start:y_end, x_start:x_end]
                
                if parallel:
                    thread = Thread(target=my_wrapper, 
                                 args=(cur_I, E, prm, 
                                      (y_start, y_end), 
                                      (x_start, x_end)))
                    threads.append(thread)
                    thread.start()
                else:
                    my_wrapper(cur_I, E, prm, 
                             (y_start, y_end), 
                             (x_start, x_end))
        
        if parallel:
            for thread in threads:
                thread.join()
                
        print(f"Time elapsed: {time.time() - start:.2f}s")
    
    return E / np.max(E)

def main():
    """Main function demonstrating edge detection"""
    # Noisy Image Demo
    print("Noisy Image Demo:")
    I = read_image("Sqr.png")
    I = I.astype(TYPE) / 255.0
    
    prm = MyParam()
    prm.slidingWindow = 0
    prm.noisyImage = True
    prm.parallel = True
    prm.splitPoints = 0
    
    # First Iteration, all Image
    E = my_run_im(I, prm)
    E = 1 - E
    show_image(E, 1, 2, True)
    
    # Real Image Demo
    print("Real Image Demo:")
    I = read_image("real/2.png")
    I = I.astype(TYPE) / 255.0
    
    prm.slidingWindow = 129
    prm.noisyImage = False
    prm.parallel = True
    prm.splitPoints = 0
    
    # First Iteration, all Image
    E = my_run_im(I, prm)
    E = 1 - E
    show_image(E, 1, 2, True)
    
    print("Finished")

if __name__ == "__main__":
    main()



